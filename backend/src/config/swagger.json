    "/api/workouts/{workoutId}": {
      "get": {
        "summary": "Get a workout by ID with exercises",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "workoutId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Workout object with exercises and previous sets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": {
                      "type": "string",
                      "example": "69b985b9458b676f67eba679"
                    },
                    "user": {
                      "type": "string",
                      "example": "699fa21e89de2ac3ad942314"
                    },
                    "name": { "type": "string", "example": "Chest" },
                    "startTime": { "type": "string", "example": "17:47" },
                    "endTime": { "type": "string", "example": "17:48" },
                    "date": {
                      "type": "string",
                      "example": "2026-03-17T16:47:53.346Z"
                    },
                    "bodyWeight": { "type": "number", "example": 73 },
                    "exercises": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": {
                            "type": "string",
                            "example": "69b985c1458b676f67eba68c"
                          },
                          "exerciseId": {
                            "type": "object",
                            "properties": {
                              "_id": {
                                "type": "string",
                                "example": "69b982dd732a2b02768e33d9"
                              },
                              "name": {
                                "type": "string",
                                "example": "Bench Press"
                              },
                              "category": {
                                "type": "string",
                                "example": "Chest"
                              }
                            }
                          },
                          "sets": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "_id": {
                                  "type": "string",
                                  "example": "64d1234abcd5678ef901234b"
                                },
                                "reps": { "type": "integer", "example": 10 },
                                "weight": { "type": "number", "example": 40 },
                                "notes": { "type": "string", "example": "" }
                              }
                            }
                          },
                          "previousSets": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "_id": {
                                  "type": "string",
                                  "example": "64d1234abcd5678ef901234b"
                                },
                                "reps": { "type": "integer", "example": 10 },
                                "weight": { "type": "number", "example": 40 },
                                "notes": { "type": "string", "example": "" }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid workout ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": { "type": "string", "example": "Invalid workout ID" }
                  }
                }
              }
            }
          },

          "404": {
            "description": "Workout not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": { "type": "string", "example": "Workout not found" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          }
        }
