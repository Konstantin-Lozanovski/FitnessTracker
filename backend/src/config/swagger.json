{
  "openapi": "3.0.0",
  "info": {
    "title": "Fitness Tracker API",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "email", "password"],
                "properties": {
                  "username": { "type": "string", "example": "johndoe" },
                  "email": { "type": "string", "example": "johndoe@gmail.com" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "type": "object",
                      "properties": {
                        "username": { "type": "string", "example": "johndoe" },
                        "email": {
                          "type": "string",
                          "example": "johndoe@gmail.com"
                        }
                      }
                    },
                    "token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": {
                      "type": "string",
                      "example": "Please provide all fields"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "User already exists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": {
                      "type": "string",
                      "example": "User already exists"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login existing user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "johndoe@gmail.com" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User successfully logged in",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "type": "object",
                      "properties": {
                        "username": { "type": "string", "example": "johndoe" },
                        "email": {
                          "type": "string",
                          "example": "johndoe@gmail.com"
                        }
                      }
                    },
                    "token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing email or password",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": {
                      "type": "string",
                      "example": "Please provide email and password"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": {
                      "type": "string",
                      "example": "Invalid credentials"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/users/me": {
      "get": {
        "summary": "Get current user's profile",
        "tags": ["Users"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Returns current user's profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": {
                      "type": "string",
                      "example": "64d1234abcd5678ef9012345"
                    },
                    "username": { "type": "string", "example": "johndoe" },
                    "email": {
                      "type": "string",
                      "example": "johndoe@gmail.com"
                    },
                    "goalWeight": { "type": "number", "example": 70 }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update current user's profile",
        "tags": ["Users"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "goalWeight": { "type": "number", "example": 75 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns updated user profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": {
                      "type": "string",
                      "example": "64d1234abcd5678ef9012345"
                    },
                    "username": { "type": "string", "example": "johndoe" },
                    "email": {
                      "type": "string",
                      "example": "johndoe@gmail.com"
                    },
                    "goalWeight": { "type": "number", "example": 75 }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request (invalid input)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": { "type": "string", "example": "Invalid input" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/exercises": {
      "get": {
        "summary": "Get all exercises",
        "tags": ["Exercises"],
        "responses": {
          "200": {
            "description": "List of all exercises",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "_id": {
                        "type": "string",
                        "example": "64d1234abcd5678ef9012345"
                      },
                      "name": { "type": "string", "example": "Bench Press" },
                      "category": { "type": "string", "example": "Chest" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new exercise",
        "tags": ["Exercises"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "category"],
                "properties": {
                  "name": { "type": "string", "example": "Squat" },
                  "category": { "type": "string", "example": "Legs" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Exercise successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": {
                      "type": "string",
                      "example": "64d1234abcd5678ef9012345"
                    },
                    "name": { "type": "string", "example": "Squat" },
                    "category": { "type": "string", "example": "Legs" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": {
                      "type": "string",
                      "example": "Please provide name and category"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/workouts": {
      "post": {
        "summary": "Create a new workout",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": {
            "description": "Workout successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": {
                      "type": "string",
                      "example": "69b996ee78148ca03dba66f4"
                    },
                    "user": {
                      "type": "string",
                      "example": "699fa21e89de2ac3ad942314"
                    },
                    "name": { "type": "string", "example": "New Workout" },
                    "startTime": { "type": "string", "example": "19:01" },
                    "date": {
                      "type": "string",
                      "example": "2026-03-17T18:01:18.384Z"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": { "type": "string", "example": "Unauthorized" }
