              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "_id": {
                        "type": "string",
                        "example": "69b985b9458b676f67eba679"
                      },
                      "user": {
                        "type": "string",
                        "example": "699fa21e89de2ac3ad942314"
                      },
                      "name": { "type": "string", "example": "Chest" },
                      "startTime": { "type": "string", "example": "17:47" },
                      "endTime": { "type": "string", "example": "17:48" },
                      "date": {
                        "type": "string",
                        "example": "2026-03-17T16:47:53.346Z"
                      },
                      "bodyWeight": { "type": "number", "example": 73 }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          }
        }
      }
